---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { siteConfig } from "@/config";
import {
	getCategoryList,
	getSortedPostsList,
	getTagList,
} from "../utils/content-utils";

const sortedPostsList = await getSortedPostsList();
const tagList = await getTagList();
const categoryList = siteConfig.category.enable ? await getCategoryList() : [];
---

<MainGridLayout title={i18n(I18nKey.archive)}>
    <ArchivePanel
        sortedPosts={sortedPostsList}
        tags={tagList.map(t => t.name)}
        categories={categoryList.map(c => c.name)}
        client:only="svelte"
    ></ArchivePanel>
</MainGridLayout>

